# ══════════════════════════════════════════════════════
#  GitHub AI Agent - Konfigürasyon Şablonu
#  Bu dosyayı .env olarak kopyalayın ve değerleri girin
# ══════════════════════════════════════════════════════

# ── GitHub Personal Access Token ──
# Gerekli yetkiler: repo, read:discussion, write:discussion
# Almak için: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# ── PostgreSQL ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=github-agents

# ── LLM Provider (swappable) ──
# Varsayılan: ollama (yerel, qwen3-coder). Seçenekler: groq | ollama | huggingface
# Cloud (groq) kullanmak isterseniz LLM_PROVIDER=groq yapıp GROQ_API_KEY girin.
LLM_PROVIDER=ollama
LLM_FALLBACK_PROVIDER=ollama
# LLM_MAX_OUTPUT_TOKENS=4096
# LLM_TEMPERATURE=0.3

# ── Groq (OpenAI-uyumlu, ücretsiz tier) ──
# Anahtar al: https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ── HuggingFace (opsiyonel) ──
# HF_API_TOKEN=
# HF_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# ── Ollama (Yerel AI — varsayılan provider) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b

# ── Hedef Diller (virgülle ayrılmış) ──
# Python'a ağırlık verilir, diğerleri de taranır
# TARGET_LANGUAGES=["Python","JavaScript","TypeScript","Go","Rust"]
# PRIMARY_LANGUAGE=Python

# ── Döngü Ayarları ──
# LOOP_INTERVAL_SECONDS=3600
# TRENDING_DAYS_AGO=7
# TRENDING_LIMIT_PER_LANGUAGE=5
# MIN_STARS_THRESHOLD=50

# ── Agentic Solver (Faz 6) ──
# Başarısız doğrulamada modele log+diff geri besleyip kaç kez yeniden denesin.
# SOLVER_MAX_ITERATIONS=3

# ── Trend / Sosyal Sinyal Toplayıcı (Faz 7) ──
# Hepsi ücretsiz + keyless (GitHub mevcut token'ı kullanır).
# TREND_SOURCES=["github_search","github_stars","hackernews","reddit"]
# TREND_REDDIT_SUBS=["programming","Python","webdev"]
# Kaynak ağırlıkları (JSON); birleşik 0-100 trend skorunu belirler.
# TREND_WEIGHTS={"github_search":0.35,"github_stars":0.30,"hackernews":0.20,"reddit":0.15}

# ── Onay Gereksinimleri ──
REQUIRE_APPROVAL_FOR_PR=true
REQUIRE_APPROVAL_FOR_COMMENT=true
